% Minimal CVPR style file for anonymous submission
\ProvidesPackage{cvpr}

% Page numbers
\RequirePackage{pagenumbers}

% Double-blind review: remove author info, suppress page numbers
\AtBeginDocument{%
  \thispagestyle{empty}
}

% Float positioning
\renewcommand{\topfraction}{0.95}
\renewcommand{\bottomfraction}{0.7}
\renewcommand{\textfraction}{0.05}
\renewcommand{\floatpagefraction}{0.95}

% Section formatting
\RequirePackage{titlesec}
\titleformat{\section}{\bfseries\large}{}{0em}{}
\titleformat{\subsection}{\bfseries\normalsize}{}{0em}{}
\titleformat{\subsubsection}{\bfseries\normalsize\itshape}{}{0em}{}

% Caption formatting
\RequirePackage{caption}
\captionsetup[figure]{font=small,labelfont=bf}
\captionsetup[table]{font=small,labelfont=bf}
